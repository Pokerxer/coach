{
  "manifest_version": 3,
  "name": "Parakeet AI",
  "version": "1.0.0",
  "description": "Real-time AI interview assistant",
  "permissions": [
    "tabCapture",
    "sidePanel",
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "side_panel": {"default_path": "popup.html"},
  "background": {"service_worker": "background.js", "type": "module"},
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Parakeet AI"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}