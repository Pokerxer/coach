{
  "manifest_version": 3,
  "name": "Parakeet AI",
  "version": "1.0.0",
  "description": "Stealth interview assistant",
  "permissions": ["tabCapture", "sidePanel", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "side_panel": {"default_path": "sidepanel.html"},
  "background": {"service_worker": "background.js", "type": "module"},
  "action": {"default_title": "Parakeet AI", "default_popup": "sidepanel.html"},
  "content_scripts": [{"matches": ["<all_urls>"], "js": ["content.js"]}]
}